    {
      "id": "26a899d0-460f-4ba4-8d36-ffd4d24ae5dd",
      "name": "Retrieve end-of-day historical data",
      "request": {
        "name": "Retrieve end-of-day historical data",
        "description": {
          "content": "Returns the end-of-day historical OHLCV time series for a given ticker symbol. The symbol must include the exchange suffix, for example AAPL.US or BMW.XETRA. One call per request regardless of date range.",
          "type": "text/plain"
        },
        "url": {
          "path": [
            "eod",
            ":symbol"
          ],
          "host": [
            "{{baseUrl}}"
          ],
          "query": [
            {
              "disabled": false,
              "key": "api_token",
              "value": "<string>",
              "description": "(Required) API token assigned to your EODHD account."
            },
            {
              "disabled": false,
              "key": "fmt",
              "value": "csv",
              "description": "Response format. Defaults to csv."
            },
            {
              "disabled": false,
              "key": "period",
              "value": "d",
              "description": "Aggregation period. d=daily, w=weekly, m=monthly."
            },
            {
              "disabled": false,
              "key": "order",
              "value": "a",
              "description": "Sort order of returned rows. a=ascending, d=descending."
            },
            {
              "disabled": false,
              "key": "from",
              "value": "<date>",
              "description": "Inclusive start date in YYYY-MM-DD format."
            },
            {
              "disabled": false,
              "key": "to",
              "value": "<date>",
              "description": "Inclusive end date in YYYY-MM-DD format."
            },
            {
              "disabled": false,
              "key": "filter",
              "value": "<string>",
              "description": "Return only a single field, e.g. last_close or last_volume."
            }
          ],
          "variable": [
            {
              "disabled": false,
              "type": "any",
              "value": "<string>",
              "key": "symbol",
              "description": "(Required) Ticker symbol with exchange suffix, e.g. AAPL.US."
            }
          ]
        },
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "method": "GET",
        "auth": null
      },
